---
layout: null
---
[
  {% for section in site.data.navigation.sections %}
    {% for category in section.categories %}
      {% for page_item in category.pages %}
        {% unless page_item.wip %}
        {
          "title": {{ page_item.title | jsonify }},
          "url": "{{ page_item.url | relative_url }}",
          "category": {{ category.title | jsonify }},
          "section": {{ section.title | jsonify }},
          "description": ""
        }{% unless forloop.last and forloop.parentloop.last and forloop.parentloop.parentloop.last %},{% endunless %}
        {% endunless %}
      {% endfor %}
    {% endfor %}
  {% endfor %}
]
