---
layout: null
---
[
  {% assign all = site.pages | where_exp: "p", "p.layout == 'page'" %}
  {% for p in all %}
  {
    "title": {{ p.title | jsonify }},
    "url": "{{ p.url | relative_url }}",
    "category": {{ p.category | jsonify }},
    "icat": {{ p.icat | jsonify }},
    "summary": {{ p.summary | jsonify }},
    "tags": {{ p.tags | join: " " | jsonify }},
    "date": "{{ p.date | date: '%Y-%m-%d' }}"
  }{% unless forloop.last %},{% endunless %}
  {% endfor %}
]
